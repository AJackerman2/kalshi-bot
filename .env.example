# ============================================================================
# Kalshi Maker Bot environment.
#
# Copy to `.env` and fill in.  Never commit `.env`.
#
# MODE governs whether real Kalshi write calls (place/cancel order) can fire.
#   - MODE=sim    : Session 1 default.  All write calls raise inside the client.
#                   Order lifecycle is fully simulated and logged.
#   - MODE=live   : DO NOT SET this session.  Reserved for Session 2 after sign-off.
# ============================================================================

MODE=sim

# --- Kalshi -----------------------------------------------------------------
# Account API key id (UUID-like string from the Kalshi dashboard).
KALSHI_API_KEY_ID=

# Absolute path to the RSA private key PEM file paired with the API key above.
# Keep mode 0600.  Never paste the key inline in this file.
KALSHI_PRIVATE_KEY_PATH=/etc/kalshi-maker-bot/kalshi_private_key.pem

# Base URL.  Production = https://api.elections.kalshi.com/trade-api/v2
# Demo / paper = https://demo-api.kalshi.co/trade-api/v2
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# --- Strategy ---------------------------------------------------------------
# Ask price range (cents) for candidate markets.
MIN_ASK_CENTS=90
MAX_ASK_CENTS=97

# How far below the ask to post our bid (cents).  Must be 1 or 2.
BID_OFFSET_CENTS=1

# Notional dollars per market (fixed, NOT Kelly).
DOLLARS_PER_MARKET=25

# Minimum hours from now to market close to consider a new entry.
MIN_HOURS_TO_CLOSE=24

# Liquidity gates.  See DECISIONS.md for thresholds.
MIN_OPEN_INTEREST=1000
MIN_RECENT_VOLUME=100

# Cancel our open bid if ask drifts more than this many cents above our bid.
CANCEL_DRIFT_CENTS=2

# Kill all open bids if market is within this many minutes of close.
CLOSE_BUFFER_MIN=10

# Refresh / replace unfilled orders every N minutes.
REFRESH_INTERVAL_MIN=5

# Skip new entries within this many minutes of a known scheduled catalyst.
CATALYST_BUFFER_MIN=30

# --- Cadence ----------------------------------------------------------------
# How often the scanner sweeps the full market list (seconds).
SCAN_INTERVAL_SEC=300

# How often the order monitor re-checks order books for open simulated orders
# (seconds).
MONITOR_INTERVAL_SEC=60

# --- Storage ----------------------------------------------------------------
DB_PATH=/var/lib/kalshi-maker-bot/state.db
EVENT_LOG_PATH=/var/log/kalshi-maker-bot/events.jsonl

# --- Google Sheets ----------------------------------------------------------
# Service-account JSON key with edit access to the target spreadsheet.
GOOGLE_CREDENTIALS_PATH=/etc/kalshi-maker-bot/google-credentials.json

# Spreadsheet id (the long token from the sheet URL).
SHEETS_SPREADSHEET_ID=

# Worksheet / tab name within the spreadsheet.
SHEETS_TAB_NAME=events

# Set to 0 to disable Sheets writes entirely (still logs to SQLite + JSONL).
SHEETS_ENABLED=1

# --- Misc -------------------------------------------------------------------
LOG_LEVEL=INFO
