# Neon Postgres connection string.  Use the *pooled* DSN from Neon for Vercel
# serverless functions.  Server-side only -- never NEXT_PUBLIC_*.
DATABASE_URL=

# Single shared password gating the dashboard.  Generate a strong value.
DASHBOARD_PASSWORD=

# Starting bankroll in cents (mirrors the bot's value).
SIM_STARTING_BANKROLL_CENTS=100000
